generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Core User ────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Location for geo-based event search
  city      String?
  lat       Float?
  lng       Float?
  radiusMi  Int      @default(25)

  weekends     Weekend[]
  activities   Activity[]
  budgetLogs   BudgetLog[]
  engagement   EngagementMetric[]
  aiLogs       AiLog[]
  availability UserAvailability[]
  savedEvents  SavedEvent[]
}

// ─── User Availability (weekly time blocks) ───────────────────────────────────

model UserAvailability {
  id         String @id @default(cuid())
  userId     String
  dayOfWeek  Int    // 0=Sun, 1=Mon ... 6=Sat
  startHour  Int    // 0-23
  endHour    Int    // 0-23
  label      String? // optional: "Morning free", "After work"

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── External Events (ingested from Eventbrite, Ticketmaster, etc.) ──────────

model ExternalEvent {
  id           String   @id @default(cuid())
  sourceId     String   // external ID from the source platform
  sourceName   String   // "eventbrite" | "ticketmaster" | "meetup"
  title        String
  description  String?
  startDateTime DateTime
  endDateTime   DateTime?
  cost         Float    @default(0)
  costMax      Float?   // for ranged pricing
  currency     String   @default("USD")
  isVirtual    Boolean  @default(false)
  isFree       Boolean  @default(false)
  locationName String?
  address      String?
  lat          Float?
  lng          Float?
  city         String?
  state        String?
  url          String
  imageUrl     String?
  category     String?
  tags         String[]
  status       String   @default("active") // active | cancelled | sold_out
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  savedBy      SavedEvent[]

  @@unique([sourceId, sourceName])
  @@index([city])
  @@index([startDateTime])
  @@index([isFree])
}

// ─── User Saved Events ────────────────────────────────────────────────────────

model SavedEvent {
  id              String        @id @default(cuid())
  userId          String
  externalEventId String
  savedAt         DateTime      @default(now())
  addedToPlanner  Boolean       @default(false)

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event           ExternalEvent @relation(fields: [externalEventId], references: [id], onDelete: Cascade)

  @@unique([userId, externalEventId])
}

// ─── Weekend Planning ─────────────────────────────────────────────────────────

model Weekend {
  id           String   @id @default(cuid())
  userId       String
  startDate    DateTime
  endDate      DateTime
  title        String?
  totalSpent   Int      @default(0)
  budgetTarget Int      @default(0)
  score        Int      @default(0)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  planned      PlannedActivity[]
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String
  baseCost    Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  planned     PlannedActivity[]
}

model PlannedActivity {
  id          String   @id @default(cuid())
  weekendId   String
  activityId  String
  date        DateTime
  startTime   String
  durationMin Int
  cost        Int
  completed   Boolean  @default(false)
  rating      Int?

  weekend     Weekend  @relation(fields: [weekendId], references: [id])
  activity    Activity @relation(fields: [activityId], references: [id])
}

// ─── Budget ───────────────────────────────────────────────────────────────────

model BudgetLog {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  category   String
  direction  String   // 'spend' or 'add'
  note       String?
  occurredAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

// ─── Engagement & AI ─────────────────────────────────────────────────────────

model EngagementMetric {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @default(now())
  loginCount     Int      @default(0)
  planningCount  Int      @default(0)
  sessionMinutes Int      @default(0)
  completionRate Float    @default(0)

  user           User     @relation(fields: [userId], references: [id])
}

model AiLog {
  id        String   @id @default(cuid())
  userId    String?
  prompt    String
  response  String
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}
